[core]
	excludesfile = /Users/ougi/.gitignore_global
	autocrlf = input
	editor = code --wait
[user]
	name = ougi
	email = ougi@to-r.net
[color]
	diff = auto
	status = auto
	branch = auto
	ui = auto
[diff]
	tool = default-difftool
[difftool "default-difftool"]
  cmd = atom --wait --diff $LOCAL $REMOTE
[commit]
	template = /Users/ougi/.stCommitMsg
[alias]
	s = status
	b = branch
	co = checkout
	a = add
	bindex = for-each-ref --sort='-authordate:iso8601' --format=' %(authordate:iso8601)%09%(refname)' refs/heads
[merge]
	tool = atom
[pull]
	ff = only
[alias]
	conflicts = !git ls-files -u | cut -f 2 | sort -u
[difftool "sourcetree"]
	cmd = " /usr/local/bin/code --wait --diff $LOCAL $REMOTE"
	path = 
[mergetool "sourcetree"]
	cmd = /usr/local/bin/code --wait $MERGED
	trustExitCode = true
